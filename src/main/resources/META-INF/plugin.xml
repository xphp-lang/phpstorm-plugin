<!--
  Plugin descriptor for the xphp PhpStorm plugin.

  Chunk 2/7 of the phpstorm-plugin track: this descriptor is intentionally
  bare bones.  No file-type registration, no LSP wiring; those come in
  chunks 3 and 4 respectively.  Goal here is `./gradlew build` produces a
  valid (but feature-less) plugin zip the verifier accepts against PhpStorm
  2026.1, so subsequent chunks add behaviour against a known-good baseline.

  The `since-build` / `until-build` window is populated from gradle.properties
  by the IntelliJ Platform Gradle Plugin's pluginConfiguration block; that's
  why this file leaves the `idea-version` element off entirely.
-->
<idea-plugin>
    <id>com.xphp.lsp</id>
    <name>xphp</name>
    <vendor email="math3usmartins@github.com" url="https://github.com/xphp-lang/xphp">xphp-lang</vendor>

    <description><![CDATA[
        Language support for <a href="https://github.com/xphp-lang/xphp">xphp</a>, a PHP
        superset with monomorphized generics that compiles to vanilla PHP.
        <br/><br/>

        Editing intelligence (diagnostics, hover, go-to-definition, completion) is delivered
        by the bundled xphp Language Server over the IntelliJ Platform LSP API.
        <br/><br/>

        Requires:<br/><br/>
        - PHP 8.4+<br/>
        - PhpStorm 2026.1 or later.
    ]]></description>

    <change-notes><![CDATA[
        <h3>0.2.1</h3>
        <ul>
            <li>Bundle xphp language server v0.2.5.</li>
        </ul>
        <h3>0.2.0</h3>
        <ul>
            <li>Bundle xphp language server v0.2.3.</li>
            <li>Match the server's namespaced <code>xphp.showReferences</code> code-lens command.</li>
        </ul>
        <h3>0.1.0</h3>
        <ul>
            <li>MVP: basic functionality to support xphp v0.1.0</li>
        </ul>
    ]]></change-notes>

    <!--
      Universal IntelliJ Platform module.  Required (since IntelliJ Platform
      2024.2+) for the plugin to be recognised as targeting any IntelliJ-
      based IDE rather than IDEA-only by default.  Without this, install
      logs warn:
        "Plugin 'xphp' is compatible with IntelliJ IDEA only because it
         doesn't define any explicit module dependencies"
    -->
    <depends>com.intellij.modules.platform</depends>

    <!--
      IntelliJ Platform LSP API module.  Required (per
      https://plugins.jetbrains.com/docs/intellij/language-server-protocol.html
      #basic-implementation): without this depends, our
      `<platform.lsp.serverSupportProvider>` extension is silently
      dropped during plugin load and the file-open path triggers
      partial wire-ups that crash editor construction
      (user-visible: "Cannot focus editor ... preferredFocusedComponent
      is null" followed by an immediate fileClosed).
    -->
    <depends>com.intellij.modules.lsp</depends>

    <!--
      The PhpStorm bundled PHP plugin gives us PSI hooks for the PHP language
      family.  We hard-depend on it so an enterprising user can't install the
      xphp plugin into IntelliJ IDEA without PHP support and end up with a
      half-broken file-type registration in chunk 3.
    -->
    <depends>com.jetbrains.php</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!--
          NOTE: we deliberately do NOT register a `<fileType>` for *.xphp.
          An earlier iteration shipped a `LanguageFileType(XphpLanguage)`
          plus a top-level `XphpLanguage`, but `LanguageFileType` makes
          the platform assume the bound `Language` has a `ParserDefinition`
          available; it walks the language hierarchy looking for one to
          build PSI when the editor opens.  We don't have a parser
          (parsing is delegated to the LSP), so editor construction failed
          and `.xphp` files refused to open at all
          ("Cannot focus editor ... preferredFocusedComponent is null" in
          idea.log, immediately followed by `fileClosed`).

          With no `<fileType>` from us, PhpStorm opens `.xphp` files as
          plain text, and our `XphpLspServerSupportProvider` routes the
          LSP by extension (`file.extension == "xphp"`), the
          docs-recommended pattern.  Highlighting comes from the LSP's
          semantic tokens, so no editor-side grammar is needed.

          See https://plugins.jetbrains.com/docs/intellij/language-server-protocol.html
          #basic-implementation for the canonical filter shape.
        -->

        <!--
          Application-level settings service for the xphp LSP binary path.
          Single instance across all open projects; a developer wants the
          same binary across every xphp project on their machine.
        -->
        <applicationService
            serviceImplementation="com.xphp.lsp.settings.XphpSettings"/>

        <!--
          Notification group for user-facing plugin messages.  Currently
          only used by XphpLspServerDescriptor to surface a balloon when
          the LSP can't start (no binary configured, no bundled PHAR
          available, or the configured path doesn't exist).  Registered
          as `BALLOON` so the message appears where the user is looking
          instead of getting buried in idea.log, and carries an
          "Open Settings..." action that jumps straight to Tools -> xPHP.
        -->
        <notificationGroup
            id="xphp"
            displayType="BALLOON"/>

        <!--
          Settings UI lives under Preferences -> Tools -> xPHP.
          `parentId="tools"` is the platform's stable id for the Tools group.
        -->
        <applicationConfigurable
            parentId="tools"
            id="com.xphp.lsp.settings.XphpSettingsConfigurable"
            displayName="xPHP"
            instance="com.xphp.lsp.settings.XphpSettingsConfigurable"/>

        <!--
          LSP server provider, registered against the IntelliJ Platform LSP
          API (available across all editions since 2025.2; 2026.1 brought the
          rest of the surface we lean on).  The provider's `fileOpened`
          method routes any .xphp file open into our descriptor.
        -->
        <platform.lsp.serverSupportProvider
            implementation="com.xphp.lsp.XphpLspServerSupportProvider"/>

        <!--
          Cycle L Half B: VFS rename listener for `.xphp` / `.php`
          files.  Sends `workspace/willRenameFiles` to the xphp LSP
          server on each rename; the response carries text edits
          renaming the in-source class to match the new basename,
          applied via WriteCommandAction.

          NOTE on why this is needed: an earlier prod-test (log id=59)
          showed a willRenameFiles request being sent to the server,
          which I initially attributed to PhpStorm's native dispatch
          based on the server's `workspace.fileOperations.willRename`
          capability advertisement.  A subsequent prod-test
          (xphp-20260530-164821) with the listener removed confirmed
          that was wrong: PhpStorm 2026.1's LSP4IJ does NOT
          dispatch willRenameFiles natively; the earlier traffic was
          this listener doing the work.  Restored.
        -->
        <vfs.asyncListener
            implementation="com.xphp.lsp.XphpFileRenameListener"/>

        <!--
          NOTE: we deliberately do NOT register a
          `<lang.syntaxHighlighterFactory language="xphp" ...>`.  Without
          an `XphpLanguage` for the LSP-only model (see the longer
          rationale above on the missing `<fileType>`), there's nothing
          to bind the factory to.  Highlighting is delivered entirely by
          the LSP's semantic tokens, which the IntelliJ LSP API applies
          on top of the plain-text editor.
        -->

        <!--
          Semantic-token colors are handled entirely in code, with NO
          extension registration here: XphpSemanticTokensSupport (wired in
          XphpLspServerDescriptor.lspCustomization) maps each LSP token type
          onto PhpStorm's own PHP highlighting key
          (com.jetbrains.php.lang.highlighter.PhpHighlightingData).  So .xphp
          code is colored exactly like PHP in whatever color scheme is active
          (stock, New UI, "Islands", or user-customized) and follows any
          edit the user makes to PHP's colors.

          An earlier iteration registered custom XPHP_* attribute keys plus
          per-scheme <additionalTextAttributes> seeds and a <colorSettingsPage>;
          that rendered black on any scheme not literally named Default/Darcula
          and never matched the user's PHP colors, so it was removed in favour
          of deferring to the PHP keys.
        -->
    </extensions>

    <!--
      Cycle L Half A (file-rename half): when the user renames an
      xphp class via Shift+F6, LSP4IJ applies the text edits but
      silently drops `RenameFile` resource ops, so the FILE stays
      at its old name even though the class is renamed.  This
      BulkFileListener watches `VFileContentChangeEvent`s for
      .xphp/.php files and, when a single-declaration PSR-4 file's
      class short name no longer matches the basename stem,
      renames the file to match.  See [XphpClassFileSync] for the
      regex-based heuristic and cycle-interaction notes (it plays
      symmetrically with Half B's file → class flow).
    -->
    <applicationListeners>
        <listener
            class="com.xphp.lsp.XphpClassFileSync"
            topic="com.intellij.openapi.vfs.newvfs.BulkFileListener"/>
    </applicationListeners>
</idea-plugin>
